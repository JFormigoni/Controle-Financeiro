# Exemplo de variáveis de ambiente. Copie para `.env.local` e preencha com valores reais.
# NUNCA versione o arquivo `.env.local` ou `.env` (veja .gitignore).

# Banco de dados PostgreSQL / Supabase (Req. 16.5)
# DATABASE_URL: conexão "pooled" (PgBouncer, porta 6543) usada pela aplicação.
#   Obrigatório o sufixo ?pgbouncer=true&connection_limit=1 para uso serverless.
# DIRECT_URL: conexão direta (porta 5432) usada por `prisma migrate deploy`.
DATABASE_URL="postgresql://postgres.ruhlsevpwuzzbublwifa:Mtvjef1409!@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.ruhlsevpwuzzbublwifa:Mtvjef1409!@aws-1-us-east-1.pooler.supabase.com:5432/postgres"

# Auth.js v5 / NextAuth (Req. 2, 14) - segredo usado para assinar/criptografar tokens de sessão
AUTH_SECRET="generate-with: openssl rand -base64 32"

# URL pública da aplicação (usada por Auth.js e links de e-mail)
NEXTAUTH_URL="http://localhost:3000"

# Provedor de e-mail (Req. 1.3, 3.1) - usado para validação de conta e recuperação de senha
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="no-reply@example.com"
